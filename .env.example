# Fichier de référence pour la configuration de développement (.env) et production (.env.prod)
# Copier ce fichier et modifier les valeurs selon ton environnement

# === Django Core Settings ===

# Mode debug (TRUE en dev, FALSE en prod)
DJANGO_DEBUG=True

# Clé secrète Django (générer avec: python manage.py shell_plus)
DJANGO_SECRET_KEY=dev-only-not-for-production-6f4e1f41c9a74b13b945b1d146e0cb6d9f2a5c03

# Domaines autorisés (en dev: localhost, en prod: tes vrais domaines)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.ngrok-free.dev,.ngrok-free.app,.ngrok.io

# Origines de confiance pour CSRF (requêtes POST cross-origin)
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.ngrok-free.dev,https://*.ngrok-free.app,https://*.ngrok.io

# === Database ===
# SQLite (dev) ou PostgreSQL/MySQL (prod)
# Laisser vide pour SQLite (défaut: db.sqlite3)

DATABASE_ENGINE=django.db.backends.sqlite3
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=reves_dev
# DATABASE_USER=reves_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# === Email ===
# Console (dev) ou SMTP (prod)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-specific-password
DJANGO_DEFAULT_FROM_EMAIL=noreply@reves-etude.fr

# === Sécurité Sessions ===
DJANGO_SESSION_COOKIE_SECURE=False  # True en prod avec HTTPS
DJANGO_CSRF_COOKIE_SECURE=False      # True en prod avec HTTPS

# === Timing ===
DJANGO_TIME_ZONE=Europe/Paris
DJANGO_LANGUAGE_CODE=fr-fr

# === Push Notifications (PWA) ===
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# === Logging ===
LOG_LEVEL=DEBUG  # DEBUG en dev, INFO en prod

# === AWS S3 (optionnel - pour fichiers statiques/media) ===
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-west-1

# === Authentification Sociale (optionnel) ===
# SOCIAL_AUTH_GOOGLE_KEY=
# SOCIAL_AUTH_GOOGLE_SECRET=
# SOCIAL_AUTH_GITHUB_KEY=
# SOCIAL_AUTH_GITHUB_SECRET=
