# Django core
# Optional: absolute path to an external env file (e.g. in mon_env)
# DJANGO_ENV_FILE=/home/maudyaiche/dev/site_reves/mon_env/reves.dev.env
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-for-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.ngrok-free.dev,https://*.ngrok-free.app,https://*.ngrok.io

# Security hardening
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=true
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_PASSWORD_RESET_TIMEOUT=86400
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Email (development defaults)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=noreply@reves-etude.fr

# Web push (optional override)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=contact@reves-etude.fr

# Logging levels
DJANGO_SECURITY_LOG_LEVEL=WARNING
DJANGO_AUTH_LOG_LEVEL=INFO
